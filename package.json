    "start-sqlite-permanent": "bun src/examples/example-sqlite-permanent.ts",
    "start-sqlite-permanent-fuse": "bun src/examples/example-sqlite-permanent-fuse-auto.ts",
    "start-sqlite-permanent-fuse-manual": "bun src/examples/example-sqlite-permanent-fuse-manual.ts",
    "start-http-server": "bun src/examples/example-http-server.ts",
    "start-http-client": "bun src/examples/example-http-client.ts"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "10.4.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/bun": "1.3.13",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
